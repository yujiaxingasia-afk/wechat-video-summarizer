<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="微信视频总结"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="状态检查中..."
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnEnableAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开启无障碍服务"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnStartCapture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开始捕获"
        android:enabled="false"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnStopCapture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="停止并总结"
        android:enabled="false"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="使用方法：\n1. 点击「开启无障碍服务」\n2. 在设置中找到「微信视频总结」并开启\n3. 返回此App，点击「开始捕获」\n4. 去微信看视频\n5. 看完后返回此App，点击「停止并总结」"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>